    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const observer = new MutationObserver(function (mutations) {
          mutations.forEach(function (mutation) {
            if (mutation.type === 'childList' || mutation.type === 'subtree') {
              applyQuantityControls(); // Reapply the event listeners whenever the DOM is modified
            }
          });
        });

        observer.observe(document.body, { childList: true, subtree: true });

        function applyQuantityControls() {
          let quantityContainers = document.querySelectorAll('.cart-item__quantity.disabled');

          if (quantityContainers) {
            quantityContainers.forEach(function (container) {
              let decreaseBtn = container.querySelector('a.quantity-down');
              let increaseBtn = container.querySelector('a.quantity-up');
              let quantityInput = container.querySelector('.cart-item__quantity-input');

              function updateButtonStates() {
                alert('dasdasd');
                if (quantityInput.value < 12) {
                  quantityInput.value = 12; // Reset to 12 if the value is lower
                }

                if (quantityInput.value <= 12) {
                  decreaseBtn?.classList.add('disabled');
                } else {
                  decreaseBtn?.classList.remove('disabled');
                }

                console.log('Triggered in the function!!');
              }

              if (decreaseBtn && increaseBtn && quantityInput) {
                updateButtonStates();

                quantityInput.addEventListener('input', function () {
                  setTimeout(() => {
                    updateButtonStates();
                    console.log('Triggered on the input!!');
                  }, 100);
                });

                decreaseBtn.addEventListener('click', function (event) {
                  event.preventDefault();
                  setTimeout(() => {
                    updateButtonStates();
                    console.log('Click on prev');
                  }, 100);
                });

                increaseBtn.addEventListener('click', function (event) {
                  event.preventDefault();
                  setTimeout(() => {
                    updateButtonStates();
                    console.log('Click on Next');
                  }, 100);
                });
              }
            });
          }
        }

        applyQuantityControls(); // Initial application of the event listeners
      });
    </script>

