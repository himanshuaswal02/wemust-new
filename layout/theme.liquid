        <script>
          document.addEventListener('DOMContentLoaded', function () {
            // --- Configuration ---
            const minQuantity = 12;

            // --- Select Elements ---
            const quantityInput = document.querySelector(".quantity-wrapper [name='quantity']");
            const decreaseBtn = document.querySelector(".quantity-wrapper [data-quantity='down']");
            const increaseBtn = document.querySelector(".quantity-wrapper [data-quantity='up']"); // We still need it for one check

            if (!quantityInput || !decreaseBtn || !increaseBtn) {
              console.warn('Quantity control elements not found for this product.');
              return;
            }

            /**
             * This single function reads the current quantity and enforces all our rules.
             * It doesn't change the quantity itself, it just validates and updates the UI.
             */
            function validateQuantityAndUpdateUI() {
              // Use a slight delay to ensure the theme's script has updated the value first.
              setTimeout(function () {
                let currentValue = parseInt(quantityInput.value, 10);

                // RULE 1: If the value is invalid or below the minimum, force it to the minimum.
                if (isNaN(currentValue) || currentValue < minQuantity) {
                  quantityInput.value = minQuantity;
                  currentValue = minQuantity; // Update our variable to match
                }

                // RULE 2: Disable or enable the decrease button based on the value.
                if (currentValue <= minQuantity) {
                  decreaseBtn.classList.add('disabled');
                } else {
                  decreaseBtn.classList.remove('disabled');
                }

                // RULE 3: Check the specific radio button if at minimum quantity.
                if (currentValue <= minQuantity) {
                  const radioOption = document.querySelector('input[type="radio"][id="option_9502584144173_7-0"]');
                  if (radioOption) {
                    radioOption.checked = true;
                  }
                }

                // ✅ ADD THIS LINE - always trigger recalculation
                quantityInput.dispatchEvent(new Event('change', { bubbles: true }));
              }, 5); // A tiny delay is often enough.
            }

            // --- Event Listeners ---

            // We listen for ANY change to the input, whether by typing, pasting, or the theme's buttons.
            // 'change' and 'input' cover all cases.
            quantityInput.addEventListener('blur', validateQuantityAndUpdateUI);

            // We add a "click" listener to the buttons ONLY to trigger our validation function.
            // We are NOT preventing the default action anymore. We let the theme do its work.
            decreaseBtn.addEventListener('click', validateQuantityAndUpdateUI);
            increaseBtn.addEventListener('click', validateQuantityAndUpdateUI);

            // --- Initial Setup ---
            // Run once on page load to set the correct state.
            validateQuantityAndUpdateUI();
          });
        </script>
      {% endif %}

      {% if product.title == 'Bumper Sticker' %}
        <script>
          document.addEventListener('DOMContentLoaded', function () {
            let decreaseBtn = document.querySelector(".quantity-wrapper [data-quantity='down']");
            let increaseBtn = document.querySelector(".quantity-wrapper [data-quantity='up']");
            let quantityInput = document.querySelector(".quantity-wrapper [name='quantity']");
            let submitBtn = document.querySelector('.quantity-submit-row__submit.input-row');

            function updateSubmitButtonState() {
              let currentValue = parseInt(quantityInput.value, 10);

              // If the value is less than 10, disable the submit button
              if (currentValue < 10 || isNaN(currentValue)) {
                submitBtn?.setAttribute('disabled', 'true');
              } else {
                submitBtn?.removeAttribute('disabled');
              }
            }

            function updateButtonStates() {
              let currentValue = parseInt(quantityInput.value, 10);

              // Disable the decrease button if the value is 10 or less
              if (currentValue <= 10 || isNaN(currentValue)) {
                decreaseBtn?.setAttribute('disabled', 'true');
              } else {
                decreaseBtn?.removeAttribute('disabled');
              }
            }

            if (decreaseBtn && increaseBtn && quantityInput && submitBtn) {
              // Set initial state
              updateSubmitButtonState();
              updateButtonStates();

              quantityInput.addEventListener('keydown', function (event) {
                // Ensure only valid numbers are typed
                let currentValue = parseInt(quantityInput.value, 10);

                // Update button states based on current value
                updateSubmitButtonState();
                updateButtonStates();
              });

              quantityInput.addEventListener('input', function () {
                let currentValue = parseInt(quantityInput.value, 10);

                // Update button states based on current value
                updateSubmitButtonState();
                updateButtonStates();
              });

              decreaseBtn.addEventListener('click', function (event) {
                event.preventDefault();
                let currentValue = parseInt(quantityInput.value, 10);
                if (currentValue > 10) {
                  quantityInput.value = currentValue - 1; // Decrease by 1
                }
                updateSubmitButtonState();
                updateButtonStates();
              });

              increaseBtn.addEventListener('click', function (event) {
                event.preventDefault();
                let currentValue = parseInt(quantityInput.value, 10) || 0;
                quantityInput.value = currentValue + 1; // Increase by 1
                updateSubmitButtonState();
                updateButtonStates();
              });
            }
          });
        </script>
      {% endif %}
