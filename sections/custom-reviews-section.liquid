{{ 'custom-reviews-section.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom-reviews-section.js' | asset_url }}" defer></script>

{%- liquid
  assign top_blocks = section.blocks | where: 'type', 'review_top'
  assign bottom_blocks = section.blocks | where: 'type', 'review_bottom'
-%}

<div
  id="section-id-{{ section.id }}"
  class="custom-reviews-section"
  style="
    --crs-background: {{ section.settings.background_color }};
    --crs-card-background: {{ section.settings.card_background }};
    --crs-kicker-color: {{ section.settings.kicker_color }};
    --crs-heading-color: {{ section.settings.heading_color }};
    --crs-text-color: {{ section.settings.text_color }};
    --crs-muted-color: {{ section.settings.muted_color }};
    --crs-star-color: {{ section.settings.star_color }};
    --crs-speed: {{ section.settings.scroll_speed }}s;
    --crs-desktop-padding-top: {{ section.settings.desktop_padding_top }}px;
    --crs-desktop-padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
    --crs-mobile-padding-top: {{ section.settings.mobile_padding_top }}px;
    --crs-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  "
>
  <div class="container custom-reviews-section__inner">
    {%- if section.settings.kicker != blank -%}
      <div class="custom-reviews-section__kicker">{{ section.settings.kicker | escape }}</div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="custom-reviews-section__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="custom-reviews-section__subheading">{{ section.settings.subheading | escape }}</div>
    {%- endif -%}
  </div>

  <custom-reviews-marquee class="custom-reviews-section__marquees" data-section-id="{{ section.id }}">
    {%- if top_blocks.size > 0 -%}
      <div class="custom-reviews-section__marquee" data-review-marquee>
        <div class="custom-reviews-section__track" data-review-track>
          {%- for block in top_blocks -%}
            {%- render 'custom-review-card', block: block -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if bottom_blocks.size > 0 -%}
      <div class="custom-reviews-section__marquee custom-reviews-section__marquee--reverse" data-review-marquee>
        <div class="custom-reviews-section__track" data-review-track>
          {%- for block in bottom_blocks -%}
            {%- render 'custom-review-card', block: block -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </custom-reviews-marquee>
</div>

{% schema %}
{
  "name": "Custom reviews",
  "class": "section-custom-reviews",
  "disabled_on": {
    "groups": [
      "aside"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "35,000+ verified reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Thousands of 5 star DTF transfer reviews"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Verified feedback from authentic customers"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 18,
      "max": 80,
      "step": 2,
      "unit": "s",
      "label": "Scroll speed",
      "default": 44
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Review card background",
      "default": "#f6f7f9"
    },
    {
      "type": "color",
      "id": "kicker_color",
      "label": "Kicker",
      "default": "#019aff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#7e8492"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Stars",
      "default": "#ffc046"
    },
    {
      "type": "header",
      "content": "desktop padding"
    },
    {
      "type": "range",
      "id": "desktop_padding_top",
      "label": "Desktop padding top",
      "min": 0,
      "max": 100,
      "default": 48
    },
    {
      "type": "range",
      "id": "desktop_padding_bottom",
      "label": "Desktop padding bottom",
      "min": 0,
      "max": 100,
      "default": 64
    },
    {
      "type": "header",
      "content": "mobile padding"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile padding top",
      "min": 0,
      "max": 100,
      "default": 32
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile padding bottom",
      "min": 0,
      "max": 100,
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "review_top",
      "name": "Review - top row",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Erika Lehrmann"
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author title"
        },
        {
          "type": "textarea",
          "id": "review",
          "label": "Review",
          "default": "I have to say, the team went above and beyond with their customer service. I am happy to say that they stand by their product."
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        }
      ]
    },
    {
      "type": "review_bottom",
      "name": "Review - bottom row",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Victoria Terry"
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author title",
          "default": "CEO"
        },
        {
          "type": "textarea",
          "id": "review",
          "label": "Review",
          "default": "Five stars are not enough. The ordering process was simple, quick, and very reasonably priced."
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom reviews",
      "blocks": [
        {
          "type": "review_top"
        },
        {
          "type": "review_top",
          "settings": {
            "author": "Peter Johnson",
            "review": "Great quality and fast turnaround. Everything arrived exactly as expected and looked fantastic."
          }
        },
        {
          "type": "review_top",
          "settings": {
            "author": "Jill Fragus",
            "review": "My order was perfect. Amazing quality prints and lightning fast turnaround time."
          }
        },
        {
          "type": "review_bottom"
        },
        {
          "type": "review_bottom",
          "settings": {
            "author": "Edward Garcia",
            "author_title": "",
            "review": "I have been loving the quality of the products I have been receiving. Our volunteers loved them."
          }
        },
        {
          "type": "review_bottom",
          "settings": {
            "author": "Kevin Kington",
            "author_title": "",
            "review": "I have ordered numerous transfers and have never been disappointed with the quality."
          }
        }
      ]
    }
  ]
}
{% endschema %}
