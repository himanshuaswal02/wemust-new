<section class="dtw-newsletter">
  <div class="dtw-newsletter-inner">

    {% if section.settings.title != blank %}
      <h2 class="dtw-newsletter-title">
        {{ section.settings.title }}
      </h2>
    {% endif %}

    {% if section.settings.subtitle != blank %}
      <p class="dtw-newsletter-subtitle">
        {{ section.settings.subtitle }}
      </p>
    {% endif %}

    {% form 'customer', class: 'dtw-newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="digital transfer">

      <div class="dtw-newsletter-form__wrapper">
        <input
          type="email"
          name="contact[email]"
          class="dtw-newsletter-input"
          placeholder="Enter your business email"
          required
        >

        <button
          type="submit"
          class="dtw-newsletter-button"
        >
          Subscribe
        </button>
      </div>

      {% if form.posted_successfully? %}
        <p class="dtw-newsletter-success">
          Thanks for subscribing!
        </p>
      {% endif %}

      {{ form.errors | default_errors }}
    {% endform %}

  </div>
</section>

{% schema %}
{
  "name": "DTW Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Be The First to Know"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "New product launches, promotions, industry insights and more."
    }
  ],
  "presets": [
    {
      "name": "DTW Newsletter"
    }
  ]
}
{% endschema %}