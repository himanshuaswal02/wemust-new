<link rel="stylesheet" href="{{ 'icons-with-text.css' | asset_url }}" {%- render 'lazy-stylesheet-attrs' %}>

<div
  id="section-id-{{ section.id }}"
  class="icons-with-text-section"
  style="
    --icons-with-text-bg: {{ section.settings.background_color }};
    --icons-with-text-card-bg: {{ section.settings.card_background_color }};
    --icons-with-text-heading-color: {{ section.settings.heading_color }};
    --icons-with-text-text-color: {{ section.settings.text_color }};
    --icons-with-text-muted-color: {{ section.settings.muted_color }};
    --icons-with-text-icon-bg: {{ section.settings.icon_background_color }};
    --icons-with-text-icon-size: {{ section.settings.icon_size }}px;
    --icons-with-text-gap: {{ section.settings.grid_gap }}px;
    --icons-with-text-columns-desktop: {{ section.settings.columns_desktop }};
    --icons-with-text-columns-mobile: {{ section.settings.columns_mobile }};
    --icons-with-text-padding-top: {{ section.settings.padding_top }}px;
    --icons-with-text-padding-bottom: {{ section.settings.padding_bottom }}px;
    --icons-with-text-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --icons-with-text-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="container">
    <div class="icons-with-text-section__inner">
      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <div class="icons-with-text-section__header {% if section.settings.heading_alignment == 'left' %} icons-with-text-section__header--left{% endif %}" data-cc-animate>
          {%- if section.settings.heading != blank -%}
            <h2 class="icons-with-text-section__heading section-heading">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}

          {%- if section.settings.subheading != blank -%}
            <div class="icons-with-text-section__subheading rte">{{ section.settings.subheading }}</div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="icons-with-text-section__grid">
        {%- for block in section.blocks -%}
          <div
            class="icons-with-text-section__card fade-in-up"
            {{ block.shopify_attributes }}
            data-cc-animate
            data-cc-animate-delay="{{ forloop.index | times: 0.12 }}s"
          >
            <div class="icons-with-text-section__icon">
              {%- if block.settings.icon_image != blank -%}
                {%- render 'image',
                  image: block.settings.icon_image,
                  class: 'icons-with-text-section__icon-image',
                  sizes: '72px',
                  widths: '48, 72, 96, 144'
                -%}
              {%- elsif block.settings.icon != blank -%}
                <span class="icons-with-text-section__icon-svg">
                  {%- render 'icon', icon: block.settings.icon, size: 'custom' -%}
                </span>
              {%- else -%}
                <div class="icons-with-text-section__icon-placeholder">
                  {{- 'image' | placeholder_svg_tag: 'placeholder-svg' -}}
                </div>
              {%- endif -%}
            </div>

            <div class="icons-with-text-section__content">
              {%- if block.settings.title != blank -%}
                <h3 class="icons-with-text-section__title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <div class="icons-with-text-section__text rte">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

