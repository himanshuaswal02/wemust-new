{{ 'custom-started-section.css' | asset_url | stylesheet_tag }}

<section class="custom-started-section">
  <div class="started-wrapper">
    <div class="started-content">
      {% if section.settings.heading != blank %}
        <h2 class="started-heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="started-text rte">
          {{ section.settings.text }}
        </div>
      {% endif %}

      <div class="started-cards">
        {% for index in (1..3) %}
          {% liquid
            assign image_key = 'card_image_' | append: index
            assign title_key = 'card_title_' | append: index
            assign text_key = 'card_text_' | append: index
            assign card_image = section.settings[image_key]
            assign card_title = section.settings[title_key]
            assign card_text = section.settings[text_key]
          %}

          <article class="started-card">
            <div class="started-card__media">
              {% if card_image != blank %}
                {{
                  card_image
                  | image_url: width: 900
                  | image_tag:
                    widths: '360, 540, 720, 900',
                    sizes: '(min-width: 990px) 30vw, (min-width: 750px) 45vw, 100vw',
                    loading: 'lazy',
                    class: 'started-card__image'
                }}
              {% else %}
                <div class="started-card__placeholder">
                  <span>{{ index }}</span>
                </div>
              {% endif %}
            </div>

            <div class="started-card__body">
              {% if card_title != blank %}
                <h3 class="started-card__title">{{ card_title | escape }}</h3>
              {% endif %}

              {% if card_text != blank %}
                <div class="started-card__text rte">
                  {{ card_text }}
                </div>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>

      {% if section.settings.button_label_1 != blank %}
        <div class="started-buttons">
          <a href="{{ section.settings.button_link_1 | default: '#' }}" class="started-btn">
            <span>{{ section.settings.button_label_1 | escape }}</span>
            <span aria-hidden="true" class="started-btn__arrow">&gt;</span>
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Started Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bring Your Designs To Life"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Custom DTF Transfers Engineered For Vibrant Colour, Sharp Detail, And Reliable Durability On Virtually Any Fabric.</p>"
    },
    {
      "type": "header",
      "content": "Card 1"
    },
    {
      "type": "image_picker",
      "id": "card_image_1",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "card_title_1",
      "label": "Title",
      "default": "Upload Your Artwork"
    },
    {
      "type": "richtext",
      "id": "card_text_1",
      "label": "Text",
      "default": "<p>Upload Your Artwork Directly To Our Platform. We Check It For Print Accuracy And Get It Ready For Production.</p>"
    },
    {
      "type": "header",
      "content": "Card 2"
    },
    {
      "type": "image_picker",
      "id": "card_image_2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "card_title_2",
      "label": "Title",
      "default": "24-48 Hour Print & Ship"
    },
    {
      "type": "richtext",
      "id": "card_text_2",
      "label": "Text",
      "default": "<p>Your Transfers Are Printed In-House With Precision And Shipped Fast, Typically Within 24-48 Hours.</p>"
    },
    {
      "type": "header",
      "content": "Card 3"
    },
    {
      "type": "image_picker",
      "id": "card_image_3",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "card_title_3",
      "label": "Title",
      "default": "Ready To Press"
    },
    {
      "type": "richtext",
      "id": "card_text_3",
      "label": "Text",
      "default": "<p>Transfers Arrive Fully Cured And Ready To Heat-Press For Consistent, Professional Results.</p>"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button label",
      "default": "Start Your Order"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Custom Started Section"
    }
  ]
}
{% endschema %}
