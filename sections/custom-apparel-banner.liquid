<link rel="stylesheet" href="{{ 'custom-apparel-banner.css' | asset_url }}" {%- render 'lazy-stylesheet-attrs' %}>
{%- if section.blocks.size > 1 -%}
  <script src="{{ 'slideshow.js' | asset_url }}" defer></script>
{%- endif -%}
{% style %}
  {% if section.settings.hide_text == true %}
    @media (max-width: 767px){
      #shopify-section-{{ section.id }} .custom-apparel-banner__inner{
        display: none;
      }
    }
  {% endif %}
{% endstyle %}
{%- liquid
  assign first_slide = section.blocks.first
  assign desktop_adapt_ratio = 2.4
  assign mobile_adapt_ratio = desktop_adapt_ratio

  if first_slide != blank and first_slide.settings.image != blank
    assign desktop_adapt_ratio = first_slide.settings.image.aspect_ratio | default: 2.4
  endif

  if first_slide != blank and first_slide.settings.mobile_image != blank
    assign mobile_adapt_ratio = first_slide.settings.mobile_image.aspect_ratio | default: desktop_adapt_ratio
  else
    assign mobile_adapt_ratio = desktop_adapt_ratio
  endif
-%}

<div
  id="section-id-{{ section.id }}"
  class="custom-apparel-banner-section fully-spaced-row--{{ section.settings.section_spacing }}"
  data-desktop-height-mode="{{ section.settings.height_mode_desktop }}"
  data-mobile-height-mode="{{ section.settings.height_mode_mobile }}"
  style="
    --cab-section-bg: {{ section.settings.section_background }};
    --cab-text-color: {{ section.settings.text_color }};
    --cab-subheading-color: {{ section.settings.subheading_color }};
    --cab-button-bg: {{ section.settings.button_background }};
    --cab-button-text: {{ section.settings.button_text_color }};
    --cab-button-hover-bg: {{ section.settings.button_hover_background }};
    --cab-button-hover-text: {{ section.settings.button_hover_text_color }};
    --cab-arrow-bg: {{ section.settings.arrow_background }};
    --cab-arrow-color: {{ section.settings.arrow_color }};
    --cab-arrow-hover-bg: {{ section.settings.arrow_hover_background }};
    --cab-arrow-hover-color: {{ section.settings.arrow_hover_color }};
    --cab-dot-color: {{ section.settings.pagination_color }};
    --cab-dot-active: {{ section.settings.pagination_active_color }};
    --cab-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --cab-content-max-width: {{ section.settings.content_max_width }}px;
    --cab-height-desktop: {{ section.settings.height_desktop }}px;
    --cab-height-mobile: {{ section.settings.height_mobile }}px;
    --cab-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --cab-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --cab-arrow-size-desktop: {{ section.settings.arrow_size_desktop }}px;
    --cab-arrow-size-mobile: {{ section.settings.arrow_size_mobile }}px;
    --cab-adapt-ratio-desktop: {{ desktop_adapt_ratio }};
    --cab-adapt-ratio-mobile: {{ mobile_adapt_ratio }};
  "
>
  <div class="{% if section.settings.full_width %}custom-apparel-banner-section__full-width{% else %}container{% endif %}">
    <slide-show
      class="custom-apparel-banner"
      data-dispatch-events="true"
      data-autoplay="{{ section.settings.autoplay }}"
      data-speed="{{ section.settings.autoplay_speed }}"
      data-transition="fade"
      data-transition-out-delay="0"
      data-pause-autoplay-on-mouseover="false"
      role="region"
      aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
      aria-label="{{ section.settings.accessibility_info | escape }}"
    >
      <div class="slideshow" id="slideshow-{{ section.id }}" aria-live="polite" aria-atomic="true">
        {%- for block in section.blocks -%}
          {%- liquid
            assign use_full_slide_link = false
            if block.settings.button_link == blank and block.settings.slide_link != blank
              assign use_full_slide_link = true
            endif
          -%}
          <div
            class="slideshow__slide custom-apparel-banner__slide{% if forloop.first %} is-active{% endif %}"
            role="group"
            aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
            aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
            {%- unless forloop.first %}tabindex="-1"{% endunless %}
            style="--slide-index: {{ forloop.index }}"
            {{ block.shopify_attributes }}
          >
            {%- if use_full_slide_link -%}
              <a class="custom-apparel-banner__slide-link" href="{{ block.settings.slide_link }}" aria-label="{{ block.settings.heading | strip_html | escape | default: block.settings.subheading | escape }}">
            {%- endif -%}

            <div class="custom-apparel-banner__media">
              {%- if block.settings.image != blank -%}
                {%- liquid
                  assign loading = 'lazy'
                  assign fetchpriority = nil
                  if forloop.first
                    assign loading = 'eager'
                    assign fetchpriority = 'high'
                  endif
                -%}
                <picture class="custom-apparel-banner__picture slideshow__motion-media">
                  {%- if block.settings.mobile_image != blank -%}
                    <source
                      media="(max-width: 767.98px)"
                      srcset="
                        {{ block.settings.mobile_image | image_url: width: 480 }} 480w,
                        {{ block.settings.mobile_image | image_url: width: 768 }} 768w,
                        {{ block.settings.mobile_image | image_url: width: 1200 }} 1200w
                      "
                      sizes="100vw"
                    >
                  {%- endif -%}
                  {{
                    block.settings.image
                    | image_url: width: 2400
                    | image_tag:
                      class: 'custom-apparel-banner__image',
                      widths: '768, 1200, 1600, 2000, 2400',
                      sizes: '100vw',
                      loading: loading,
                      fetchpriority: fetchpriority
                  }}
                </picture>
              {%- else -%}
                <div class="slideshow__motion-media">
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>

            <div class="custom-apparel-banner__overlay"></div>

            <div class="custom-apparel-banner__inner">
              <div class="custom-apparel-banner__content custom-apparel-banner__content--{{ block.settings.content_alignment }}">
                {%- if block.settings.heading != blank -%}
                  <h2 class="custom-apparel-banner__heading">{% render 'multiline-text' with block.settings.heading %}</h2>
                {%- endif -%}
                {%- if block.settings.subheading != blank -%}
                  <div class="custom-apparel-banner__subheading">{{ block.settings.subheading | escape }}</div>
                {%- endif -%}
                
                {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
                  <div class="custom-apparel-banner__actions">
                    <a class="custom-apparel-banner__button" href="{{ block.settings.button_link }}">
                      {{ block.settings.button_label | escape }}
                    </a>
                  </div>
                {%- endif -%}
              </div>
            </div>

            {%- if use_full_slide_link -%}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > 1 -%}
        <div class="custom-apparel-banner__controls js-only">
          <div class="slideshow-nav">
            <button type="button" class="slideshow-nav__btn has-ltr-icon" name="prev" aria-controls="slideshow-{{ section.id }}">
              <span class="visually-hidden">{{ 'general.slider.previous' | t }}</span>
              {% render 'icon-chevron-left' %}
            </button>

            <button type="button" class="slideshow-nav__btn has-ltr-icon" name="next" aria-controls="slideshow-{{ section.id }}">
              <span class="visually-hidden">{{ 'general.slider.next' | t }}</span>
              {% render 'icon-chevron-right' %}
            </button>
          </div>
        </div>

        <div class="slideshow-pagination custom-apparel-banner__pagination js-only" role="tablist" aria-label="{{ section.settings.pagination_label | escape }}">
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="page-btn custom-apparel-banner__page-btn"
              data-index="{{ forloop.index0 }}"
              aria-controls="slideshow-{{ section.id }}"
              aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
              {% if forloop.first %}aria-current="true"{% endif %}
            >
              <span class="visually-hidden">{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }}</span>
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </slide-show>
  </div>
</div>

{% schema %}
{
  "name": "Custom apparel banner",
  "class": "section-custom-apparel-banner",
  "disabled_on": {
    "groups": ["aside"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "hide_text",
      "label": "Hide text From Mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full page width",
      "default": true
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "Section spacing",
      "default": "medium",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "header",
      "content": "Height settings"
    },
    {
      "type": "select",
      "id": "height_mode_desktop",
      "label": "Desktop image height",
      "default": "fixed",
      "options": [
        { "value": "fixed", "label": "Fixed height" },
        { "value": "adapt", "label": "Adapt to image" }
      ]
    },
    {
      "type": "select",
      "id": "height_mode_mobile",
      "label": "Mobile image height",
      "default": "fixed",
      "options": [
        { "value": "fixed", "label": "Fixed height" },
        { "value": "adapt", "label": "Adapt to image" }
      ]
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Desktop height",
      "min": 420,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 660,
      "info": "Used when desktop image height is set to fixed height."
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Mobile height",
      "min": 220,
      "max": 520,
      "step": 10,
      "unit": "px",
      "default": 280,
      "info": "Used when mobile image height is set to fixed height."
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 220,
      "max": 800,
      "step": 10,
      "unit": "px",
      "default": 520
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Desktop heading size",
      "min": 32,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Mobile heading size",
      "min": 24,
      "max": 56,
      "step": 1,
      "unit": "px",
      "default": 34
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "%",
      "default": 14
    },
    {
      "type": "header",
      "content": "Slider settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Change slides every",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 3
    },
    {
      "type": "color_background",
      "id": "section_background",
      "label": "Section background",
      "default": "#5e0d18"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading and text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button colors"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#7d1823"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#f3d9de"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button hover text",
      "default": "#7d1823"
    },
    {
      "type": "header",
      "content": "Arrow colors"
    },
    {
      "type": "range",
      "id": "arrow_size_desktop",
      "label": "Arrow size on desktop",
      "min": 40,
      "max": 70,
      "step": 1,
      "unit": "px",
      "default": 55
    },
    {
      "type": "range",
      "id": "arrow_size_mobile",
      "label": "Arrow size on mobile",
      "min": 28,
      "max": 44,
      "step": 1,
      "unit": "px",
      "default": 33
    },
    {
      "type": "color",
      "id": "arrow_background",
      "label": "Arrow background",
      "default": "#00000080"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow icon color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_hover_background",
      "label": "Arrow hover background",
      "default": "#861528e6"
    },
    {
      "type": "color",
      "id": "arrow_hover_color",
      "label": "Arrow hover icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Pagination colors"
    },
    {
      "type": "color",
      "id": "pagination_color",
      "label": "Pagination outline color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "pagination_active_color",
      "label": "Active pagination color",
      "default": "#9f2033"
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "accessibility_info",
      "label": "Slider description",
      "default": "Custom apparel banner slider"
    },
    {
      "type": "text",
      "id": "pagination_label",
      "label": "Pagination label",
      "default": "Banner slide navigation"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },        
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "info": "Enter <br> for a line break",
          "default": "FOR EVERY BUSINESS"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Custom Apparel Decoration Solutions"
        },        
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Order now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "url",
          "id": "slide_link",
          "label": "Whole slide link",
          "info": "Used when button link is empty, making the full banner clickable."
        },
        {
          "type": "select",
          "id": "content_alignment",
          "label": "Content alignment",
          "default": "left",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom apparel banner",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "subheading": "Custom Apparel Decoration Solutions",
            "heading": "FOR EVERY BUSINESS",
            "button_label": "Order now",
            "content_alignment": "left"
          }
        },
        {
          "type": "slide",
          "settings": {
            "subheading": "Print-Ready Blank Apparel",
            "heading": "BLANK APPAREL<br>READY TO GO",
            "button_label": "Order blank apparel",
            "content_alignment": "left"
          }
        }
      ]
    }
  ]
}
{% endschema %}
