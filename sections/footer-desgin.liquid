.wemust-footer {
  background: url('https://wemust-nest.s3.ca-central-1.amazonaws.com/1770368833619_Rectangle_4716.png');
  color: #ffffff;
  width: 100%;
  padding: 90px 20px 20px;
  font-family: "poppins", sans-serif;
  background-size: cover;
  margin-top: 55px;
}

.footer-container {
  max-width: 1400px;
  margin: 0 auto;
}

/* Logo Section */
.footer-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 40px;
}

.footer-logo-img {
  width: 150px;
  margin-bottom: 22px;
}

.footer-logo-text {
  font-size: 18px;
  font-weight: 600;
  color: #ffffff;
  margin: 0;
  margin-bottom: 5px;
}

.footer-logo-tagline {
  font-size: 14px;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.9);
  margin: 0;
  font-style: italic;
}

/* Footer Content */
.footer-content {
  width: 100%;
}

/* Desktop Layout (1280px+) */
.footer-top-desktop {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30px;
  margin-bottom: 40px;
}



.footer-bottom-section-desktop {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30px;
  margin-top: 20px;
  margin-bottom: 20px;
  align-items: flex-start;
}

.footer-bottom-left {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30px;
}

.footer-contact-box-right {
  background-color: rgba(255, 255, 255, 0.1);
  padding: 25px;
  border-radius: 20px;
  display: flex;
  flex-direction: column;
}

/* Tablet Layout (800px - 1279px) - Hidden by default */
.footer-columns-tablet {
  display: none;
  grid-template-columns: 1fr 1fr;
  gap: 30px;
  margin-bottom: 40px;
}

.footer-tablet-left,
.footer-tablet-right {
  display: flex;
  flex-direction: column;
  gap: 30px;
}

/* Mobile Layout (1px - 799px) - Hidden by default */
.footer-columns-mobile {
  display: none;
  flex-direction: column;
  gap: 30px;
  margin-bottom: 40px;
}

.footer-bottom-mobile {
  display: none;
  margin-top: 20px;
}

/* Column Styles */
.footer-column {
  display: flex;
  flex-direction: column;
}

.footer-column-title {
  font-size: 14px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 15px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.footer-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.footer-list li {
  font-size: 14px;
  line-height: 1.5;
}

.footer-link {
  color: rgba(255, 255, 255, 0.9);
  cursor: pointer;
  transition: color 0.3s ease;
  display: inline-block;
}

.footer-link:hover {
  color: #ffffff;
  text-decoration: underline;
}

/* Contact Section */
.footer-contact-box {
  display: flex;
  flex-direction: column;
  background-color: #9f4755;
  padding: 20px;
  border-radius: 8px;
}

.footer-contact-box-right {
  background-color: #9f4755;
  padding: 25px;
  border-radius: 20px;
  display: flex;
  flex-direction: column;
}

.footer-contact-details-3 {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.footer-contact-section {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.footer-contact-info {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 20px;
}

.footer-phone,
.footer-email {
  color: #ffffff;
  text-decoration: none;
  font-size: 14px;
  transition: opacity 0.3s ease;
}

.footer-phone:hover,
.footer-email:hover {
  opacity: 0.8;
  text-decoration: underline;
}

/* Social Media Icons */
.footer-social-icons {
  display: flex;
  gap: 12px;
  margin-bottom: 20px;
}

.footer-social-icon {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 18px;
  transition: background-color 0.3s ease;
  text-decoration: none;
}

.footer-social-icon:hover {
  background-color: rgba(255, 255, 255, 0.2);
}

/* Payment Logos */
.footer-payment-logos {
  display: flex;
  gap: 10px;
  align-items: center;
  flex-wrap: wrap;
}

.payment-logo {
  height: 34px;
  width: auto;
}

/* Enterprise Name */
.footer-enterprise-name {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.7);
  margin: 0;
  margin-top: 15px;
  font-weight: 400;
}

/* Copyright Section */
.footer-copyright {
  border-top: 1px solid rgba(255, 255, 255, 0.2);
  padding-top: 20px;
  margin-top: 30px;
}

.footer-copyright-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 15px;
}

.footer-copyright-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.8);
  margin: 0;
}

.footer-legal-links {
  display: flex;
  gap: 10px;
  align-items: center;
}

.footer-legal-link {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.8);
  cursor: pointer;
  transition: color 0.3s ease;
}

.footer-legal-link:hover {
  color: #ffffff;
  text-decoration: underline;
}

.footer-legal-separator {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
}

/* Responsive Design */

/* Desktop (1280px+) */
@media (min-width: 1280px) {
  .footer-top-desktop {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }

  .footer-bottom-section-desktop {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }


  .hide{
    display: none;
  }

  .footer-bottom-left {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }

  .footer-columns-tablet {
    display: none;
  }

  .footer-columns-mobile {
    display: none;
  }

  .footer-bottom-mobile {
    display: none;
  }
}

/* Tablet (800px - 1279px) */
@media (min-width: 800px) and (max-width: 1279px) {
  .footer-top-desktop {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 25px;
  }

  .wemust-footer{
    background-color: #861528 !important;
  }

  .footer-bottom-section-desktop {
    display: grid;
    grid-template-columns: 1fr;
    gap: 25px;
  }

  .footer-bottom-left {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 25px;
  }

  .footer-columns-tablet {
    display: none;
  }

  .footer-bottom-mobile {
    display: none;
  }
}

/* Mobile (1px - 799px) */
@media (max-width: 799px) {
  .wemust-footer {
    padding: 30px 15px 15px;
  }

  .footer-logo {
    margin-bottom: 30px;
  }

  .footer-top-desktop {
    display: grid;
    gap: 25px;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  }

  button.footer-link {
    text-align: left;
}

  .footer-bottom-section-desktop {
    display: grid;
    grid-template-columns: 1fr;
    gap: 25px;
  }

  .footer-bottom-left {
    display: grid;
    gap: 25px;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  }

  .footer-columns-tablet {
    display: none;
  }

  .footer-columns-mobile {
    display: none;
  }

  .footer-bottom-mobile {
    display: none;
  }

  .footer-column-title {
    font-size: 13px;
    margin-bottom: 12px;
  }

  .footer-list {
    gap: 8px;
  }

  .footer-list li {
    font-size: 13px;
  }

  .footer-copyright-content {
    flex-direction: column;
    text-align: center;
  }

  .footer-legal-links {
    justify-content: center;
  }
}

/* Small Mobile (max-width: 480px) */
@media (max-width: 480px) {
  .footer-logo-img {
    width: 100px;
    height: 90px;
  }

  .right_text span {
    font-size: 12px;
  }

  .min-w-\[150px\] {
    min-width: 44px;
}

.cursor-pointer .w-\[100px\] {
  width: 65px;
}

button.text-white.p-2.hover\:bg-gray-800.rounded-lg.transition-colors {
  background: #000;
}

  .right_icons a,
  button.text-xs.text-gray-700.hover\:text-\[\#861528\].transition-colors {
    font-family: 'Poppins', sans-serif;
    font-size: 11px;
    font-weight: 500;
  }


  .wemust-footer,.faq-hero {
    background-color: #861528 !important  ;
   
  }

